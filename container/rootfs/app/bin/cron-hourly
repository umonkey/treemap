#!/bin/sh
set -e
cd /app

bin/treemap osm-pull \
    && curl -s -o /dev/null 'https://hc-ping.com/b5e948ce-a5bf-4ae2-94a2-a85733901bc5'

# Push new trees.
bin/treemap osm-push \
    && curl -s -o /dev/null 'https://hc-ping.com/8117cd7c-3ca9-42d4-b80a-06ccbde3b4e6'

# Push updates to existing trees.
#bin/treemap osm-push-changes
