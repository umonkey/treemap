yerevan.treemaps.app, api.treemaps.app, treemaps.app, www.treemaps.app {
	log
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}

	# Redirect root and www domains to the Yerevan subdomain.
	@redirects host treemaps.app www.treemaps.app
	handle @redirects {
		redir https://yerevan.treemaps.app{uri} permanent
	}

	# Enable compression for faster loading.
	encode zstd gzip

	# The backend serves both the API and the static frontend.
	# It has been updated to allow hidden files in .well-known for TWA verification.
	reverse_proxy backend:8000
}
